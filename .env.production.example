# ==============================================================================
# HELIX PRODUCTION ENVIRONMENT CONFIGURATION
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Frontend Configuration (Vercel Build/Runtime)
# ------------------------------------------------------------------------------
# Public URL where the backend FastAPI modular monolith is hosted
NEXT_PUBLIC_API_URL=https://helix-backend.up.railway.app

# ------------------------------------------------------------------------------
# 2. Backend Database Connectivity (Neon PostgreSQL)
# ------------------------------------------------------------------------------
# Cloud PostgreSQL database connection string (Neon / Railway PostgreSQL)
DATABASE_URL=postgresql://user:password@ep-endpoint-name.us-east-2.aws.neon.tech/neondb?sslmode=require

# ------------------------------------------------------------------------------
# 3. Google Gemini API Credentials
# ------------------------------------------------------------------------------
# API Key for Gemini reasoning models (1.5 Flash / Pro)
GEMINI_API_KEY=AIzaSyYourGeminiApiKeyHere

# ------------------------------------------------------------------------------
# 4. System Settings
# ------------------------------------------------------------------------------
# Runtime environment environment target (production / staging / development)
APP_ENV=production

# Logging severity threshold (DEBUG / INFO / WARNING / ERROR / CRITICAL)
LOG_LEVEL=INFO

# ------------------------------------------------------------------------------
# 5. Spatial GIS Providers Configuration
# ------------------------------------------------------------------------------
# Geocoder service provider (nominatim / mock)
GEOCODER_PROVIDER=nominatim

# Nearby assets lookup provider (overpass / mock)
PLACES_PROVIDER=overpass
