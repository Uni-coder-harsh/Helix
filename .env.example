# Helix Configuration - Environment Variables Example
# Copy this file to .env for local development

# General Configuration
APP_NAME=helix-backend
ENVIRONMENT=dev
LOG_LEVEL=DEBUG

# Application HTTP Settings
HOST=0.0.0.0
PORT=8000

# Backend Relational Database Configuration
# Default sqlite for local mock runs
DATABASE_URL=sqlite:///./helix.db
# Production PostgreSQL example
# POSTGRES_URL=postgresql://helix_user:secure_password@postgres:5432/helix_db

# NoSQL & Caching Services
# MONGODB_URI=mongodb://root:secure_password@mongodb:27017/helix?authSource=admin
# REDIS_URL=redis://redis:6379/0

# ==============================
# AI Configuration
# ==============================
LLM_PROVIDER=mock
LLM_MODEL=gemini-1.5-flash
GEMINI_API_KEY=
LLM_TIMEOUT=30
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2048

# Spatial Geo-Intelligence Platform Config
MAP_PROVIDER=osm
GEOCODER_PROVIDER=nominatim
GEOCODER_BASE_URL=https://nominatim.openstreetmap.org
PLACES_PROVIDER=overpass
PLACES_BASE_URL=https://overpass-api.de/api/interpreter

# Object Storage Configuration
# MINIO_ENDPOINT=http://minio:9000
# S3_BUCKET=helix-assets

# Identity & OAuth Configurations
# JWT_SECRET_KEY=generate-a-secure-32-byte-hex-key-for-jwt-signing
# GOOGLE_CLIENT_ID=your-google-oauth-client-id
# GITHUB_CLIENT_ID=your-github-oauth-client-id

# Notification Configurations
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587

# Cloud Provider Settings
# GCP_PROJECT=helix-platform-prod
